# Entra app registration (single tenant, Application permission: Reports.Read.All, admin-consented).
# See docs/SETUP.md. Pick ONE credential below.
TENANT_ID=your-directory-tenant-id
CLIENT_ID=your-application-client-id

# --- Option A: client secret (easiest — copy the value from the portal) ---
CLIENT_SECRET=your-client-secret-value

# --- Option B: certificate (preferred for production — no 24-month expiry) ---
# Leave CLIENT_SECRET blank and set these instead:
# CLIENT_CERT_PATH=/path/to/private-key.pem
# CLIENT_CERT_THUMBPRINT=ABCDEF0123456789ABCDEF0123456789ABCDEF01
