<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>M365 Wrapped — {{ stats.tenant_label }}</title>
<style>
  :root { color-scheme: dark; }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: Inter, -apple-system, "Segoe UI", Roboto, sans-serif;
    background: radial-gradient(1200px 700px at 80% -10%, #16233f 0%, #0b1220 55%) fixed, #0b1220;
    color: #fff; padding: 64px 24px 80px; -webkit-font-smoothing: antialiased;
  }
  .wrap { max-width: 1120px; margin: 0 auto; }
  header { text-align: center; margin-bottom: 48px; }
  .eyebrow { font-size: 14px; letter-spacing: .28em; text-transform: uppercase;
             color: #8aa0c6; font-weight: 600; }
  h1 { font-size: clamp(34px, 6vw, 60px); font-weight: 800; letter-spacing: -1px; margin-top: 12px; }
  h1 span { background: linear-gradient(90deg, #5B8DEF, #3FB0BC); -webkit-background-clip: text;
            background-clip: text; color: transparent; }
  .sub { color: #93a4c2; margin-top: 12px; font-size: 17px; }
  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
          gap: 22px; margin-top: 40px; }
  .card { border-radius: 22px; overflow: hidden; background: #0e1730;
          border: 1px solid rgba(255,255,255,.06); box-shadow: 0 12px 40px rgba(0,0,0,.35);
          transition: transform .15s ease; }
  .card:hover { transform: translateY(-4px); }
  .card img { display: block; width: 100%; height: auto; }
  footer { text-align: center; margin-top: 56px; color: #7f90ad; font-size: 15px; }
  footer a { color: #3FB0BC; text-decoration: none; font-weight: 600; }
</style>
</head>
<body>
  <div class="wrap">
    <header>
      <div class="eyebrow">{{ stats.tenant_label }} · last {{ stats.period[1:] }} days</div>
      <h1>Your <span>Microsoft 365</span>, wrapped.</h1>
      <p class="sub">{{ stats.cards|length }} shareable cards · org-aggregate · read-only</p>
    </header>
    <div class="grid">
      {% for c in stats.cards %}
      <div class="card"><img src="cards/{{ c.key }}.png" alt="{{ c.title }}: {{ c.value }}"></div>
      {% endfor %}
    </div>
    <footer>Generated by <a href="https://github.com/wintive/m365-wrapped">M365 Wrapped</a>
      · built by <a href="https://wintive.com">Wintive</a></footer>
  </div>
</body>
</html>
