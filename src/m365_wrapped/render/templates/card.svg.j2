<svg xmlns="http://www.w3.org/2000/svg" width="1080" height="1080" viewBox="0 0 1080 1080" font-family="Inter, 'DejaVu Sans', 'Segoe UI', sans-serif">
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#0B1220"/>
      <stop offset="1" stop-color="{{ accent_dark }}"/>
    </linearGradient>
    <radialGradient id="glow" cx="0.82" cy="0.16" r="0.7">
      <stop offset="0" stop-color="{{ accent }}" stop-opacity="0.55"/>
      <stop offset="0.55" stop-color="{{ accent }}" stop-opacity="0.10"/>
      <stop offset="1" stop-color="{{ accent }}" stop-opacity="0"/>
    </radialGradient>
    <linearGradient id="value" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#FFFFFF"/>
      <stop offset="1" stop-color="{{ accent_tint }}"/>
    </linearGradient>
  </defs>

  <!-- backdrop -->
  <rect width="1080" height="1080" fill="url(#bg)"/>
  <rect width="1080" height="1080" fill="url(#glow)"/>
  <rect x="28" y="28" width="1024" height="1024" rx="52" fill="none" stroke="#FFFFFF" stroke-opacity="0.07" stroke-width="2"/>

  {% if logo_href %}
  <!-- MSP / client logo (QBR mode) -->
  <image href="{{ logo_href }}" x="440" y="58" width="200" height="66" preserveAspectRatio="xMidYMid meet"/>
  {% endif %}

  <!-- eyebrow (auto-fit: never clips, however long the tenant name) -->
  <text x="540" y="150" text-anchor="middle" fill="#FFFFFF" fill-opacity="0.62"
        font-size="{{ eyebrow_size }}" font-weight="600" letter-spacing="{{ eyebrow_ls }}"
        {% if eyebrow_textlength %}textLength="{{ eyebrow_textlength }}" lengthAdjust="spacingAndGlyphs"{% endif %}>{{ eyebrow }}</text>

  <!-- icon -->
  <g transform="translate(540, 300)" stroke="{{ accent_tint }}" stroke-width="15"
     stroke-linecap="round" stroke-linejoin="round" fill="none">
    {{ icon | safe }}
  </g>

  <!-- value -->
  <text x="540" y="{{ value_y }}" text-anchor="middle" fill="url(#value)"
        font-size="{{ value_size }}" font-weight="800" letter-spacing="-2">{{ card.value }}</text>

  <!-- title -->
  <text x="540" y="{{ title_y }}" text-anchor="middle" fill="#FFFFFF" fill-opacity="0.92"
        font-size="52" font-weight="600">{{ card.title }}</text>

  <!-- subtitle pill -->
  {% if card.subtitle %}
  <g transform="translate(540, {{ pill_y }})">
    <rect x="{{ -pill_w // 2 }}" y="-42" width="{{ pill_w }}" height="72" rx="36"
          fill="{{ accent }}" fill-opacity="0.16"/>
    <text x="0" y="6" text-anchor="middle" fill="{{ accent_tint }}"
          font-size="36" font-weight="500">{{ card.subtitle }}</text>
  </g>
  {% endif %}

  <!-- footer -->
  <text x="540" y="1004" text-anchor="middle" fill="#FFFFFF" fill-opacity="0.50"
        font-size="28" font-weight="500" letter-spacing="1">{{ footer }}</text>
</svg>
